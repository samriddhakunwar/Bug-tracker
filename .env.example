# BugTracker API - Environment Configuration Template
# Copy this file to .env.local and update with your local values

# Database Configuration
DB_SERVER=localhost
DB_PORT=3306
DB_NAME=bugtracker_db
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# JWT Configuration
JWT_SECRET_KEY=BugTracker_SuperSecretKey_ChangeInProduction_MinLength32Chars!
JWT_ISSUER=BugTrackerAPI
JWT_AUDIENCE=BugTrackerClient
JWT_EXPIRY_HOURS=24

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:7123;http://localhost:5163

# Logging
LOG_LEVEL=Information

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=wwwroot/uploads
